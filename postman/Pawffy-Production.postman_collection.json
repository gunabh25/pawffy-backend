    {
      "name": "📅 Bookings — Full Flow",
      "description": "Complete 5-step booking flow matching the app screens:\n1. Select Service → GET /api/vets/:vetId/services (in Vets folder)\n2. Select Date/Slot → GET /api/vets/:vetId/slots?date=... (in Vets folder)\n3. Select Pet → GET /api/pets (in Pets folder)\n4. Enter Symptoms/Reason → collected client-side\n5. Create Booking → POST /api/bookings\n6. Price Summary → GET /api/payments/summary/:bookingId\n7. Apply Coupon → POST /api/payments/apply-coupon\n8. Confirm Payment → POST /api/payments/confirm\n9. Booking Confirmed → GET /api/bookings/:id",
      "item": [
        {
          "name": "STEP 5 — Create Booking (after selecting all options)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data && r.data.id) {",
                  "  pm.collectionVariables.set('bookingId', r.data.id);",
                  "  console.log('bookingId saved:', r.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"petId\": \"{{petId}}\",\n  \"vetId\": \"{{vetId}}\",\n  \"serviceId\": \"{{serviceId}}\",\n  \"bookingType\": \"veterinarian\",\n  \"bookingDate\": \"2026-07-15\",\n  \"bookingTime\": \"11:00\",\n  \"reasonForVisit\": \"My dog has been lethargic for 2 days\",\n  \"symptoms\": \"Vomiting,Lethargy,Loss of appetite\",\n  \"symptomsDuration\": \"2 Days ago\",\n  \"notes\": \"Please check ears as well\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "bookingType values: veterinarian | grooming | walking | training | boarding | sitting\n\nsymptoms: comma-separated string (Vomiting, Diarrhea, Loss of appetite, Coughing, Fever, Lethargy, Others)\n\nsymptomsDuration: 'Today' | '2 Days ago' | 'A week ago' | 'More than a week'",
            "url": { "raw": "{{baseUrl}}/api/bookings", "host": ["{{baseUrl}}"], "path": ["api", "bookings"] }
          }
        },
        {
          "name": "STEP 6 — Price Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/payments/summary/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "summary", "{{bookingId}}"],
              "query": [{ "key": "coupon", "value": "SAVE10", "disabled": true, "description": "Optional coupon code" }]
            },
            "description": "Screen 6 — Price Summary\nReturns: servicePrice + platformFee ($5) + tax (5%) - discount = total\nAlso returns pawPoints earned on this booking."
          }
        },
        {
          "name": "STEP 7 — Apply Coupon",
          "request": {
