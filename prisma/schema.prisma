generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  admin
  partner
  vet
}

enum ServiceType {
  vet
  groomer
  walker
  trainer
  sitter
  boarding
  transport
  poop_scooper
}

enum BookingType {
  veterinarian
  grooming
  walking
  training
  boarding
  sitting
  sitter
  poop_scooper
  transport
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum NotificationType {
  booking
  payment
  health
  general
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  clerkId      String?  @unique @map("clerk_id")
  name         String?
  email        String?  @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(customer)
  profileImage String?  @map("profile_image")
  address      String?
  city         String?
  state        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  pets               Pet[]
  bookings           Booking[]
  notifications      Notification[]
  passwordResetTokens PasswordResetToken[]
  sentMessages       Message[]            @relation("MessageSender")
  conversations1     Conversation[]       @relation("ConversationUser1")
  conversations2     Conversation[]       @relation("ConversationUser2")
  vetReviews         VetReview[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Pet {
  id                String   @id @default(uuid()) @db.Uuid
  ownerId           String   @map("owner_id") @db.Uuid
  name              String
  species           String
  breed             String?
  gender            String?
  age               Int?
  weight            Decimal? @db.Decimal(5, 2)
  color             String?
  medicalNotes      String?  @map("medical_notes")
  vaccinationStatus String?  @map("vaccination_status")
  imageUrl          String?  @map("image_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]

  @@map("pets")
}

model Vet {
  id              String      @id @default(uuid()) @db.Uuid
  name            String
  email           String      @unique
  serviceType     ServiceType @default(vet) @map("service_type")
  specialization  String?
  experienceYears Int?        @map("experience_years")
  clinicName      String?     @map("clinic_name")
  clinicAddress   String?     @map("clinic_address")
  clinicCity      String?     @map("clinic_city")
  profileImage    String?     @map("profile_image")
  phone           String?
  consultationFee Decimal?    @map("consultation_fee") @db.Decimal(10, 2)
  rating          Decimal?    @db.Decimal(3, 2)
  city            String?
  state           String?
  availableStatus Boolean     @default(true) @map("available_status")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  bookings       Booking[]
  availability   VetAvailability[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]
  reviews        VetReview[]
  services       VetService[]

  @@map("vets")
}

model VetService {
  id          String   @id @default(uuid()) @db.Uuid
  vetId       String   @map("vet_id") @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int      @default(30)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  vet      Vet       @relation(fields: [vetId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("vet_services")
}

model VetAvailability {
  id           String  @id @default(uuid()) @db.Uuid
  vetId        String  @map("vet_id") @db.Uuid
  dayOfWeek    String  @map("day_of_week")
  startTime    String  @map("start_time")
  endTime      String  @map("end_time")
  slotDuration Int     @default(30) @map("slot_duration")
  isAvailable  Boolean @default(true) @map("is_available")

  vet Vet @relation(fields: [vetId], references: [id], onDelete: Cascade)

  @@map("vet_availability")
}

model VetReview {
  id        String   @id @default(uuid()) @db.Uuid
  vetId     String   @map("vet_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  bookingId String?  @unique @map("booking_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  vet  Vet     @relation(fields: [vetId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vetId, userId])
  @@map("vet_reviews")
}

model Booking {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  petId             String        @map("pet_id") @db.Uuid
  vetId             String?       @map("vet_id") @db.Uuid
  serviceId         String?       @map("service_id") @db.Uuid
  bookingType       BookingType   @map("booking_type")
  bookingDate       DateTime      @map("booking_date") @db.Date
  bookingTime       String        @map("booking_time")
  status            BookingStatus @default(pending)
  reasonForVisit    String?       @map("reason_for_visit")
  symptoms          String?
  symptomsDuration  String?       @map("symptoms_duration")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet     Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet     Vet?        @relation(fields: [vetId], references: [id])
  service VetService? @relation(fields: [serviceId], references: [id])
  payment Payment?

  @@map("bookings")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  bookingId     String        @unique @map("booking_id") @db.Uuid
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  platformFee   Decimal       @default(5) @map("platform_fee") @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  couponCode    String?       @map("coupon_code")
  amount        Decimal       @db.Decimal(10, 2)
  pawPoints     Int           @default(0) @map("paw_points")
  paymentMethod String?       @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  transactionId String?       @map("transaction_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Coupon {
  id         String    @id @default(uuid()) @db.Uuid
  code       String    @unique
  discount   Decimal   @db.Decimal(5, 2)
  isPercent  Boolean   @default(true) @map("is_percent")
  maxUses    Int?      @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("coupons")
}

model MedicalRecord {
  id           String   @id @default(uuid()) @db.Uuid
  petId        String   @map("pet_id") @db.Uuid
  diagnosis    String?
  prescription String?
  allergies    String?
  symptoms     String?
  reportUrl    String?  @map("report_url")
  createdByVet String?  @map("created_by_vet") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  pet Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet Vet? @relation(fields: [createdByVet], references: [id])

  @@map("medical_records")
}

model Vaccination {
  id              String    @id @default(uuid()) @db.Uuid
  petId           String    @map("pet_id") @db.Uuid
  vaccineName     String    @map("vaccine_name")
  vaccinationDate DateTime  @map("vaccination_date") @db.Date
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  vetId           String?   @map("vet_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  pet Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet Vet? @relation(fields: [vetId], references: [id])

  @@map("vaccinations")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String
  message   String
  type      NotificationType @default(general)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Conversation {
  id          String   @id @default(uuid()) @db.Uuid
  user1Id     String   @map("user1_id") @db.Uuid
  user2Id     String   @map("user2_id") @db.Uuid
  lastMessage String?  @map("last_message")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@map("messages")
}
