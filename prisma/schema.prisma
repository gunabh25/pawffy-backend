generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  customer
  admin
  partner
  vet
}

enum ServiceType {
  vet
  groomer
  walker
  trainer
  sitter
  boarding
  transport
  poop_scooper
}

enum BookingType {
  veterinarian
  grooming
  walking
  training
  boarding
  sitting
  sitter
  poop_scooper
  transport
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum NotificationType {
  booking
  payment
  health
  general
}

enum ReportType {
  Lost
  Found
}

enum OnboardingStep {
  business
  services
  availability
  documents
  review
  submitted
}

enum VerificationStatus {
  incomplete
  pending
  verified
  rejected
}

enum PriceType {
  fixed
  range
}

enum ServiceLocationType {
  at_my_place
  at_client_place
}

enum DocumentType {
  business_license
  other
}

enum PartnerBookingStatus {
  pending
  confirmed
  completed
  cancelled
  rejected
}

enum PartnerServicePhase {
  not_started
  started
  in_progress
  completed
}

enum SupportTicketCategory {
  technical_issue
  account_issue
  booking_issue
  payment_issue
  general
}

enum ContactVerificationType {
  email_change
  phone_update
  login_phone_2fa
}

enum AdoptionStatus {
  pending_review
  info_requested
  rejected
  meet_approved
  meet_scheduled
  not_ready_yet
  approved
  declined
  documents_pending
  payment_pending
  completed
}

enum AdoptionReviewDecision {
  approve_to_meet
  request_info
  reject
}

enum AdoptionMeetingType {
  in_person
  virtual
  phone_call
}

enum AdoptionMeetOutcome {
  approve_adoption
  decline
  not_ready_yet
}

enum AdoptionDocumentType {
  adoption_agreement
  vaccination_record
  transfer_certificate
  identity_proof
  address_proof
  other
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  clerkId      String?  @unique @map("clerk_id")
  name         String?
  email        String?  @unique
  phone        String?  @unique
  pendingEmail  String?  @unique @map("pending_email")
  pendingPhone  String?  @unique @map("pending_phone")
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  passwordHash  String   @map("password_hash")
  tokenVersion  Int      @default(0) @map("token_version")
  role          Role     @default(customer)
  profileImage  String?  @map("profile_image")
  address      String?
  city         String?
  state        String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  pets                Pet[]
  bookings            Booking[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  sentMessages        Message[]            @relation("MessageSender")
  conversations1      Conversation[]       @relation("ConversationUser1")
  conversations2      Conversation[]       @relation("ConversationUser2")
  vetReviews          VetReview[]
  petReports          PetReport[]
  walkingBookings     WalkingBooking[]     @relation("WalkingBookingUser")
  partnerWalkBookings WalkingBooking[]     @relation("WalkingBookingPartner")
  partnerBusiness     PartnerBusiness?
  partnerBookings     PartnerBooking[]     @relation("PartnerBookingCustomer")
  businessReviews     BusinessReview[]
  supportTickets      SupportTicket[]
  contactVerificationTokens ContactVerificationToken[]
  adoptionApplications AdoptionApplication[] @relation("AdoptionApplicant")

  @@map("users")
}

model ContactVerificationToken {
  id           String                  @id @default(uuid()) @db.Uuid
  userId       String                  @map("user_id") @db.Uuid
  type         ContactVerificationType
  targetValue  String                  @map("target_value")
  tokenHash    String                  @map("token_hash")
  expiresAt    DateTime                @map("expires_at")
  usedAt       DateTime?               @map("used_at")
  attemptCount Int                     @default(0) @map("attempt_count")
  createdAt    DateTime                @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
  @@index([targetValue, type])
  @@map("contact_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model Pet {
  id                String   @id @default(uuid()) @db.Uuid
  ownerId           String   @map("owner_id") @db.Uuid
  name              String
  species           String
  breed             String?
  gender            String?
  age               Int?
  weight            Decimal? @db.Decimal(5, 2)
  color             String?
  medicalNotes      String?  @map("medical_notes")
  vaccinationStatus String?  @map("vaccination_status")
  imageUrl          String?  @map("image_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]
  adoptionApplications AdoptionApplication[]

  @@map("pets")
}

model Vet {
  id              String      @id @default(uuid()) @db.Uuid
  name            String
  email           String      @unique
  serviceType     ServiceType @default(vet) @map("service_type")
  specialization  String?
  experienceYears Int?        @map("experience_years")
  clinicName      String?     @map("clinic_name")
  clinicAddress   String?     @map("clinic_address")
  clinicCity      String?     @map("clinic_city")
  profileImage    String?     @map("profile_image")
  phone           String?
  consultationFee Decimal?    @map("consultation_fee") @db.Decimal(10, 2)
  rating          Decimal?    @db.Decimal(3, 2)
  city            String?
  state           String?
  availableStatus Boolean     @default(true) @map("available_status")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  bookings       Booking[]
  availability   VetAvailability[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]
  reviews        VetReview[]
  services       VetService[]

  @@map("vets")
}

model VetService {
  id          String   @id @default(uuid()) @db.Uuid
  vetId       String   @map("vet_id") @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int      @default(30)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  vet      Vet       @relation(fields: [vetId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@map("vet_services")
}

model VetAvailability {
  id           String  @id @default(uuid()) @db.Uuid
  vetId        String  @map("vet_id") @db.Uuid
  dayOfWeek    String  @map("day_of_week")
  startTime    String  @map("start_time")
  endTime      String  @map("end_time")
  slotDuration Int     @default(30) @map("slot_duration")
  isAvailable  Boolean @default(true) @map("is_available")

  vet Vet @relation(fields: [vetId], references: [id], onDelete: Cascade)

  @@map("vet_availability")
}

model VetReview {
  id        String   @id @default(uuid()) @db.Uuid
  vetId     String   @map("vet_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  bookingId String?  @unique @map("booking_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  vet  Vet     @relation(fields: [vetId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vetId, userId])
  @@map("vet_reviews")
}

model Booking {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  petId             String        @map("pet_id") @db.Uuid
  vetId             String?       @map("vet_id") @db.Uuid
  serviceId         String?       @map("service_id") @db.Uuid
  bookingType       BookingType   @map("booking_type")
  bookingDate       DateTime      @map("booking_date") @db.Date
  bookingTime       String        @map("booking_time")
  status            BookingStatus @default(pending)
  reasonForVisit    String?       @map("reason_for_visit")
  symptoms          String?
  symptomsDuration  String?       @map("symptoms_duration")
  notes             String?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet     Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet     Vet?        @relation(fields: [vetId], references: [id])
  service VetService? @relation(fields: [serviceId], references: [id])
  payment Payment?

  @@map("bookings")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  bookingId     String        @unique @map("booking_id") @db.Uuid
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  platformFee   Decimal       @default(5) @map("platform_fee") @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  couponCode    String?       @map("coupon_code")
  amount        Decimal       @db.Decimal(10, 2)
  pawPoints     Int           @default(0) @map("paw_points")
  paymentMethod String?       @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  transactionId String?       @map("transaction_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Coupon {
  id         String    @id @default(uuid()) @db.Uuid
  code       String    @unique
  discount   Decimal   @db.Decimal(5, 2)
  isPercent  Boolean   @default(true) @map("is_percent")
  maxUses    Int?      @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  expiresAt  DateTime? @map("expires_at")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("coupons")
}

model MedicalRecord {
  id           String   @id @default(uuid()) @db.Uuid
  petId        String   @map("pet_id") @db.Uuid
  diagnosis    String?
  prescription String?
  allergies    String?
  symptoms     String?
  reportUrl    String?  @map("report_url")
  createdByVet String?  @map("created_by_vet") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  pet Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet Vet? @relation(fields: [createdByVet], references: [id])

  @@map("medical_records")
}

model Vaccination {
  id              String    @id @default(uuid()) @db.Uuid
  petId           String    @map("pet_id") @db.Uuid
  vaccineName     String    @map("vaccine_name")
  vaccinationDate DateTime  @map("vaccination_date") @db.Date
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  vetId           String?   @map("vet_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  pet Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet Vet? @relation(fields: [vetId], references: [id])

  @@map("vaccinations")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String
  message   String
  type      NotificationType @default(general)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Conversation {
  id          String   @id @default(uuid()) @db.Uuid
  user1Id     String   @map("user1_id") @db.Uuid
  user2Id     String   @map("user2_id") @db.Uuid
  lastMessage String?  @map("last_message")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user1    User      @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2    User      @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages Message[]

  @@unique([user1Id, user2Id])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  content        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id])

  @@map("messages")
}

model PetReport {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  postType    ReportType @map("post_type")
  name        String?
  age         Int?
  color       String
  height      String?
  weight      String?
  breed       String?
  gender      String?
  description String
  images      String[]
  latitude    Decimal    @db.Decimal(10, 7)
  longitude   Decimal    @db.Decimal(10, 7)
  address     String
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pet_reports")
}

model WalkingBooking {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  partnerId       String        @map("partner_id") @db.Uuid
  walkingType     String        @map("walking_type")
  selectedDays    String        @map("selected_days")
  walkingDuration String        @map("walking_duration")
  selectedAddress Json          @map("selected_address")
  selectedPetList Json          @map("selected_pet_list")
  selectedService Json          @map("selected_service")
  selectedPackage Json?         @map("selected_package")
  isPackage       Boolean       @default(false) @map("is_package")
  slotTime        Json          @map("slot_time")
  paymentStatus   String        @default("Pending") @map("payment_status")
  status          BookingStatus @default(pending)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User @relation("WalkingBookingUser", fields: [userId], references: [id], onDelete: Cascade)
  partner User @relation("WalkingBookingPartner", fields: [partnerId], references: [id])

  @@map("walking_bookings")
}

model PartnerBusiness {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  businessName         String?            @map("business_name")
  contactName          String?            @map("contact_name")
  phone                String?
  location             String?
  city                 String?
  state                String?
  description          String?
  profileTitle         String?            @map("profile_title")
  isOnline             Boolean            @default(true) @map("is_online")
  sameDayRequests      Boolean            @default(false) @map("same_day_requests")
  onboardingStep       OnboardingStep     @default(business) @map("onboarding_step")
  verificationStatus   VerificationStatus @default(incomplete) @map("verification_status")
  rejectionReason      String?            @map("rejection_reason")
  termsAcceptedAt      DateTime?          @map("terms_accepted_at")
  submittedAt          DateTime?          @map("submitted_at")
  verifiedAt           DateTime?          @map("verified_at")
  membershipPlan       String             @default("free") @map("membership_plan")
  membershipExpiresAt  DateTime?          @map("membership_expires_at")
  rating               Decimal?           @db.Decimal(3, 2)
  reviewCount          Int                @default(0) @map("review_count")
  pushRequests         Boolean            @default(true) @map("push_requests")
  pushMessages         Boolean            @default(true) @map("push_messages")
  emailMarketing       Boolean            @default(false) @map("email_marketing")
  smsAlerts            Boolean            @default(true) @map("sms_alerts")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     PartnerService[]
  availability PartnerAvailability[]
  documents    PartnerDocument[]
  blockedDates PartnerBlockedDate[]
  bookings     PartnerBooking[]
  reviews      BusinessReview[]
  adoptionApplications AdoptionApplication[]

  @@map("partner_businesses")
}

model PartnerService {
  id              String              @id @default(uuid()) @db.Uuid
  businessId      String              @map("business_id") @db.Uuid
  serviceType     ServiceType         @map("service_type")
  name            String
  description     String?
  inclusions      String[]            @default([])
  durationMinutes Int                 @default(60) @map("duration_minutes")
  priceType       PriceType           @default(fixed) @map("price_type")
  price           Decimal?            @db.Decimal(10, 2)
  minPrice        Decimal?            @map("min_price") @db.Decimal(10, 2)
  maxPrice        Decimal?            @map("max_price") @db.Decimal(10, 2)
  serviceLocation ServiceLocationType @default(at_my_place) @map("service_location")
  isActive        Boolean             @default(true) @map("is_active")
  sortOrder       Int                 @default(0) @map("sort_order")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  business PartnerBusiness  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings PartnerBooking[]

  @@map("partner_services")
}

model PartnerAvailability {
  id          String  @id @default(uuid()) @db.Uuid
  businessId  String  @map("business_id") @db.Uuid
  dayOfWeek   String  @map("day_of_week")
  startTime   String  @map("start_time")
  endTime     String  @map("end_time")
  isAvailable Boolean @default(true) @map("is_available")

  business PartnerBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
  @@map("partner_availability")
}

model PartnerDocument {
  id           String       @id @default(uuid()) @db.Uuid
  businessId   String       @map("business_id") @db.Uuid
  documentType DocumentType @default(business_license) @map("document_type")
  fileName     String       @map("file_name")
  mimeType     String       @map("mime_type")
  fileData     String       @map("file_data")
  createdAt    DateTime     @default(now()) @map("created_at")

  business PartnerBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("partner_documents")
}

model PartnerBlockedDate {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @map("business_id") @db.Uuid
  date       DateTime @db.Date
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  business PartnerBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@map("partner_blocked_dates")
}

model PartnerBooking {
  id           String               @id @default(uuid()) @db.Uuid
  businessId   String               @map("business_id") @db.Uuid
  customerId   String               @map("customer_id") @db.Uuid
  petId        String?              @map("pet_id") @db.Uuid
  serviceId    String?              @map("service_id") @db.Uuid
  serviceName  String               @map("service_name")
  petName      String?              @map("pet_name")
  petBreed     String?              @map("pet_breed")
  petAge       String?              @map("pet_age")
  petImageUrl  String?              @map("pet_image_url")
  bookingDate  DateTime             @map("booking_date") @db.Date
  bookingTime  String               @map("booking_time")
  location     String?
  price        Decimal              @db.Decimal(10, 2)
  status       PartnerBookingStatus @default(pending)
  servicePhase PartnerServicePhase  @default(not_started) @map("service_phase")
  notes        String?
  isNew        Boolean              @default(true) @map("is_new")
  respondedAt  DateTime?            @map("responded_at")
  startedAt    DateTime?            @map("started_at")
  inProgressAt DateTime?            @map("in_progress_at")
  completedAt  DateTime?            @map("completed_at")
  progressData Json?                @map("progress_data")
  completionSummary String?         @map("completion_summary")
  serviceMedia Json?                @map("service_media")
  serviceLatitude Decimal?          @map("service_latitude") @db.Decimal(10, 7)
  serviceLongitude Decimal?         @map("service_longitude") @db.Decimal(10, 7)
  serviceAddress String?            @map("service_address")
  lastLocationAt DateTime?          @map("last_location_at")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  business PartnerBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer User            @relation("PartnerBookingCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  service  PartnerService? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  review   BusinessReview?

  @@index([businessId, status])
  @@index([businessId, bookingDate])
  @@map("partner_bookings")
}

model SupportTicket {
  id          String                @id @default(uuid()) @db.Uuid
  userId      String                @map("user_id") @db.Uuid
  subject     String
  category    SupportTicketCategory @default(general)
  description String
  status      String                @default("open")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("support_tickets")
}

model AdoptionApplication {
  id                String               @id @default(uuid()) @db.Uuid
  businessId        String               @map("business_id") @db.Uuid
  petId             String               @map("pet_id") @db.Uuid
  applicantId       String               @map("applicant_id") @db.Uuid
  status            AdoptionStatus       @default(pending_review)
  reviewDecision    AdoptionReviewDecision? @map("review_decision")
  reviewNotes       String?              @map("review_notes")
  rejectionReason   String?              @map("rejection_reason")
  applicationData   Json?                @map("application_data")
  applicantProfile  Json?                @map("applicant_profile")
  meetApprovedAt    DateTime?            @map("meet_approved_at")
  meetScheduledFor  DateTime?            @map("meet_scheduled_for")
  meetTimeSlot      String?              @map("meet_time_slot")
  meetingType       AdoptionMeetingType? @map("meeting_type")
  meetingNotes      String?              @map("meeting_notes")
  meetOutcome       AdoptionMeetOutcome? @map("meet_outcome")
  meetOutcomeNotes  String?              @map("meet_outcome_notes")
  meetOutcomeAt     DateTime?            @map("meet_outcome_at")
  approvedAt        DateTime?            @map("approved_at")
  declinedAt        DateTime?            @map("declined_at")
  completedAt       DateTime?            @map("completed_at")
  requestedInfoAt   DateTime?            @map("requested_info_at")
  feeAmount         Decimal              @default(150) @map("fee_amount") @db.Decimal(10, 2)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  business   PartnerBusiness   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pet        Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  applicant  User              @relation("AdoptionApplicant", fields: [applicantId], references: [id], onDelete: Cascade)
  documents  AdoptionDocument[]
  payment    AdoptionPayment?

  @@index([businessId, status])
  @@index([applicantId, status])
  @@index([petId])
  @@map("adoption_applications")
}

model AdoptionDocument {
  id           String              @id @default(uuid()) @db.Uuid
  adoptionId   String              @map("adoption_id") @db.Uuid
  documentType AdoptionDocumentType @default(other) @map("document_type")
  fileName     String              @map("file_name")
  mimeType     String              @map("mime_type")
  fileData     String              @map("file_data")
  createdAt    DateTime            @default(now()) @map("created_at")

  adoption AdoptionApplication @relation(fields: [adoptionId], references: [id], onDelete: Cascade)

  @@index([adoptionId, createdAt])
  @@map("adoption_documents")
}

model AdoptionPayment {
  id            String        @id @default(uuid()) @db.Uuid
  adoptionId    String        @unique @map("adoption_id") @db.Uuid
  subtotal      Decimal       @default(150) @db.Decimal(10, 2)
  platformFee   Decimal       @default(0) @map("platform_fee") @db.Decimal(10, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  couponCode    String?       @map("coupon_code")
  amount        Decimal       @db.Decimal(10, 2)
  pawPoints     Int           @default(0) @map("paw_points")
  paymentMethod String?       @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  transactionId String?       @map("transaction_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  adoption AdoptionApplication @relation(fields: [adoptionId], references: [id], onDelete: Cascade)

  @@index([paymentStatus, createdAt])
  @@map("adoption_payments")
}

model BusinessReview {
  id           String          @id @default(uuid()) @db.Uuid
  businessId   String          @map("business_id") @db.Uuid
  userId       String          @map("user_id") @db.Uuid
  bookingId    String          @unique @map("booking_id") @db.Uuid
  rating       Int
  comment      String?
  replyContent String?         @map("reply_content")
  repliedAt    DateTime?       @map("replied_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  business PartnerBusiness @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking  PartnerBooking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@map("business_reviews")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String?  @unique
  iconUrl   String?  @map("icon_url")
  status    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Banner {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?
  bannerWeb String?  @map("banner_web")
  bannerApp String?  @map("banner_app")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}
