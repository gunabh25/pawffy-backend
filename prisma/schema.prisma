generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  admin
  partner
  vet
}

enum BookingType {
  veterinarian
  walking
  grooming
  boarding
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum NotificationType {
  booking
  payment
  health
  general
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  clerkId      String?  @unique @map("clerk_id")
  name         String?
  email        String?  @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(customer)
  profileImage String?  @map("profile_image")
  address      String?
  city         String?
  state        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  pets          Pet[]
  bookings      Booking[]
  notifications Notification[]

  @@map("users")
}

model Pet {
  id                String   @id @default(uuid()) @db.Uuid
  ownerId           String   @map("owner_id") @db.Uuid
  name              String
  species           String
  breed             String?
  gender            String?
  age               Int?
  weight            Decimal? @db.Decimal(5, 2)
  color             String?
  medicalNotes      String?  @map("medical_notes")
  vaccinationStatus String?  @map("vaccination_status")
  imageUrl          String?  @map("image_url")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  owner          User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]

  @@map("pets")
}

model Vet {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  email           String   @unique
  specialization  String?
  experienceYears Int?     @map("experience_years")
  clinicName      String?  @map("clinic_name")
  consultationFee Decimal? @map("consultation_fee") @db.Decimal(10, 2)
  rating          Decimal? @db.Decimal(2, 1)
  city            String?
  state           String?
  availableStatus Boolean  @default(true) @map("available_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  bookings       Booking[]
  availability   VetAvailability[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]

  @@map("vets")
}

model VetAvailability {
  id           String  @id @default(uuid()) @db.Uuid
  vetId        String  @map("vet_id") @db.Uuid
  dayOfWeek    String  @map("day_of_week")
  startTime    String  @map("start_time")
  endTime      String  @map("end_time")
  slotDuration Int     @default(30) @map("slot_duration")
  isAvailable  Boolean @default(true) @map("is_available")

  vet Vet @relation(fields: [vetId], references: [id], onDelete: Cascade)

  @@map("vet_availability")
}

model Booking {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  petId           String        @map("pet_id") @db.Uuid
  vetId           String?       @map("vet_id") @db.Uuid
  bookingType     BookingType   @map("booking_type")
  bookingDate     DateTime      @map("booking_date") @db.Date
  bookingTime     String        @map("booking_time")
  status          BookingStatus @default(pending)
  symptoms  String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet     Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet     Vet?     @relation(fields: [vetId], references: [id])
  payment Payment?

  @@map("bookings")
}

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  bookingId     String        @unique @map("booking_id") @db.Uuid
  amount        Decimal       @db.Decimal(10, 2)
  paymentMethod String?       @map("payment_method")
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  transactionId String?       @map("transaction_id")
  paidAt        DateTime?     @map("paid_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model MedicalRecord {
  id           String   @id @default(uuid()) @db.Uuid
  petId        String   @map("pet_id") @db.Uuid
  diagnosis    String?
  prescription String?
  allergies    String?
  symptoms     String?
  reportUrl    String?  @map("report_url")
  createdByVet String?  @map("created_by_vet") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  pet Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet Vet? @relation(fields: [createdByVet], references: [id])

  @@map("medical_records")
}

model Vaccination {
  id              String    @id @default(uuid()) @db.Uuid
  petId           String    @map("pet_id") @db.Uuid
  vaccineName     String    @map("vaccine_name")
  vaccinationDate DateTime  @map("vaccination_date") @db.Date
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  vetId           String?   @map("vet_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  pet Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  vet Vet? @relation(fields: [vetId], references: [id])

  @@map("vaccinations")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  title     String
  message   String
  type      NotificationType @default(general)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

